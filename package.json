{
  "name": "leyline",
  "version": "0.0.0",
  "private": true,
  "bin": {
    "leyline": "bin/leyline"
  },
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build && vitepress build docs",
    "preview": "vite preview",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "local-publish": "./scripts/local-publish.sh",
    "electron:dev": "LEYLINE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "electron:build": "./scripts/electron-build.sh",
    "screenshot": "node scripts/screenshot.js",
    "video": "node scripts/video.js",
    "video:mp4": "node scripts/video-mp4.js"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "0.75.4",
    "@pierre/diffs": "1.2.0-beta.6",
    "@vitejs/plugin-vue": "latest",
    "@xterm/addon-fit": "0.11.0",
    "@xterm/xterm": "6.0.0",
    "markdown-it": "14.1.1",
    "node-pty": "1.1.0",
    "vite": "latest",
    "vue": "latest",
    "ws": "8.20.1"
  },
  "devDependencies": {
    "@electron/packager": "latest",
    "electron": "^42.1.0",
    "playwright": "1.60.0",
    "vitepress": "1.6.4"
  }
}
