{
  "name": "leyline",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "local-publish": "./scripts/local-publish.sh",
    "electron:dev": "LEYLINE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "electron:build": "npm run build && electron-packager . Leyline --out release --overwrite --prune=true --icon assets/icon --asar.unpack='**/{*.node,spawn-helper}' --ignore='^/(screenshots|src|scripts)(/|$)' --ignore='^/vite.config.js$'",
    "screenshot": "node scripts/screenshot.js",
    "video": "node scripts/video.js",
    "video:mp4": "node scripts/video-mp4.js"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "0.74.0",
    "@pierre/diffs": "1.2.0-beta.6",
    "@vitejs/plugin-vue": "latest",
    "@xterm/xterm": "6.0.0",
    "markdown-it": "14.1.1",
    "node-pty": "1.1.0",
    "vite": "latest",
    "vue": "latest",
    "ws": "8.20.1"
  },
  "devDependencies": {
    "@electron/packager": "latest",
    "electron": "^42.1.0",
    "playwright": "1.60.0"
  }
}
