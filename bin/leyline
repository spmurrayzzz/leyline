#!/usr/bin/env bash
set -euo pipefail

cwd="${LEYLINE_CWD:-$PWD}"
app_path="${LEYLINE_APP:-/Applications/Leyline.app}"
new_window=0

while (($#)); do
  case "$1" in
    -n)
      new_window=1
      shift
      ;;
    *)
      echo "usage: leyline [-n]" >&2
      exit 2
      ;;
  esac
done

if [[ ! -d "$app_path" ]]; then
  repo_app="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)/release/Leyline-darwin-arm64/Leyline.app"
  if [[ -d "$repo_app" ]]; then
    app_path="$repo_app"
  else
    echo "Leyline.app not found. Build and install it with npm run local-publish." >&2
    exit 1
  fi
fi

executable="$app_path/Contents/MacOS/Leyline"
if [[ ! -x "$executable" ]]; then
  echo "Leyline executable not found at $executable." >&2
  exit 1
fi

args=(--leyline-new-session --leyline-cwd="$cwd")
if [[ "$new_window" -eq 1 ]]; then
  args+=(--leyline-new-window)
fi

"$executable" "${args[@]}" >/dev/null 2>&1 &
